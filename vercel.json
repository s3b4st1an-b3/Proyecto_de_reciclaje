{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "app.py": {
      "includeFiles": "api/modelo_reciclaje.onnx*"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self)" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
